# Copy to `.env` (next to the compose file) and fill in.
# Every value referenced by `${VAR}` in statewave-connectors.toml must
# be present here OR exported in the shell when you run `docker compose`.

# Statewave server connection (required)
STATEWAVE_URL=https://api.example.com
STATEWAVE_API_KEY=replace-me
# STATEWAVE_TENANT_ID=                  # uncomment for multi-tenant

# /metrics auth (only used if [runner.metrics.auth] is enabled)
STATEWAVE_METRICS_TOKEN=replace-me-with-a-random-string

# Per-connector credentials — only set what your config references
GITHUB_TOKEN=ghp_replace_me
SLACK_SIGNING_SECRET=replace-me

# Postgres state — only needed when [runner.state] kind = "postgres"
# POSTGRES_PASSWORD=replace-me-with-a-strong-password
