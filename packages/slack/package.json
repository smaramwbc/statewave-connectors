{
  "name": "@statewavedev/connectors-slack",
  "version": "0.3.2",
  "description": "Slack connector for Statewave — channel/thread pull + Events-API webhook (messages, reactions, pins) + DM + MPIM (group DM) ingestion",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git",
    "directory": "packages/slack"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave-connectors/issues"
  },
  "keywords": [
    "statewave",
    "connectors",
    "slack",
    "ai",
    "agents",
    "memory"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "engines": { "node": ">=20" },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@statewavedev/connectors-core": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
