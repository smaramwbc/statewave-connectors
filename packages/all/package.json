{
  "name": "@statewavedev/connectors",
  "version": "0.1.0",
  "description": "Convenience meta-package — re-exports all official Statewave connectors. NOT required for normal usage; install only the connector packages you need.",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git",
    "directory": "packages/all"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave-connectors/issues"
  },
  "keywords": [
    "statewave",
    "connectors",
    "ai",
    "agents",
    "memory"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "engines": { "node": ">=20" },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@statewavedev/connectors-core": "workspace:^",
    "@statewavedev/connectors-github": "workspace:^",
    "@statewavedev/connectors-markdown": "workspace:^",
    "@statewavedev/connectors-slack": "workspace:^",
    "@statewavedev/connectors-n8n": "workspace:^",
    "@statewavedev/connectors-zapier": "workspace:^",
    "@statewavedev/connectors-discord": "workspace:^",
    "@statewavedev/connectors-zendesk": "workspace:^",
    "@statewavedev/connectors-intercom": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
