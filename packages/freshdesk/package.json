{
  "name": "@statewavedev/connectors-freshdesk",
  "version": "0.2.0",
  "description": "Freshdesk connector for Statewave — tickets and conversations as customer-scoped episodes (pull + webhook receiver)",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git",
    "directory": "packages/freshdesk"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave/issues"
  },
  "keywords": [
    "statewave",
    "connectors",
    "freshdesk",
    "ai",
    "agents",
    "memory",
    "support"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "engines": { "node": ">=20" },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@statewavedev/connectors-core": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^2.1.0",
    "@types/node": "^24.13.1"
  }
}
