{
  "name": "@statewavedev/mcp-server",
  "version": "0.4.8",
  "description": "Statewave MCP server — exposes Statewave memory to MCP-compatible clients",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave/issues"
  },
  "keywords": [
    "statewave",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "memory"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "statewave-mcp-server": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@statewavedev/connectors-core": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "@types/node": "^24.13.2"
  }
}
