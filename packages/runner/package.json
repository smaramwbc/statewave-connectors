{
  "name": "@statewavedev/connectors-runner",
  "version": "0.3.0",
  "description": "The hosted runner for Statewave connectors — schedules pull syncs, multiplexes push receivers under one HTTP server, and exposes /healthz + /readyz for orchestrators",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git",
    "directory": "packages/runner"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave/issues"
  },
  "keywords": [
    "statewave",
    "connectors",
    "runner",
    "daemon",
    "scheduler",
    "ai",
    "agents",
    "memory"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "engines": { "node": ">=20" },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@statewavedev/connectors-config": "workspace:^",
    "@statewavedev/connectors-core": "workspace:^",
    "@statewavedev/connectors-discord": "workspace:^",
    "@statewavedev/connectors-freshdesk": "workspace:^",
    "@statewavedev/connectors-github": "workspace:^",
    "@statewavedev/connectors-gmail": "workspace:^",
    "@statewavedev/connectors-intercom": "workspace:^",
    "@statewavedev/connectors-markdown": "workspace:^",
    "@statewavedev/connectors-n8n": "workspace:^",
    "@statewavedev/connectors-notion": "workspace:^",
    "@statewavedev/connectors-slack": "workspace:^",
    "@statewavedev/connectors-zendesk": "workspace:^",
    "croner": "^10.0.1",
    "prom-client": "^15.1.0"
  },
  "peerDependencies": {
    "ioredis": ">=5",
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "ioredis": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "@types/node": "^24.13.2"
  }
}
