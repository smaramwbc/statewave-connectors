{
  "name": "@statewavedev/connectors-cli",
  "version": "0.4.3",
  "description": "CLI for Statewave connectors \u2014 doctor, sync, listen, run, validate-config, replay, test, mcp",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave/issues"
  },
  "keywords": [
    "statewave",
    "connectors",
    "cli",
    "ai",
    "agents",
    "memory"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "statewave-connectors": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.tsbuildinfo",
    "!**/*.test.*"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@statewavedev/connectors-config": "workspace:^",
    "@statewavedev/connectors-core": "workspace:^",
    "@statewavedev/connectors-runner": "workspace:^",
    "@statewavedev/connectors-github": "workspace:^",
    "@statewavedev/connectors-gitlab": "workspace:^",
    "@statewavedev/connectors-bitbucket": "workspace:^",
    "@statewavedev/connectors-gitea": "workspace:^",
    "@statewavedev/connectors-azure-devops": "workspace:^",
    "@statewavedev/connectors-jira": "workspace:^",
    "@statewavedev/connectors-database": "workspace:^",
    "@statewavedev/connectors-markdown": "workspace:^",
    "@statewavedev/connectors-slack": "workspace:^",
    "@statewavedev/connectors-n8n": "workspace:^",
    "@statewavedev/connectors-zapier": "workspace:^",
    "@statewavedev/connectors-discord": "workspace:^",
    "@statewavedev/connectors-zendesk": "workspace:^",
    "@statewavedev/connectors-intercom": "workspace:^",
    "@statewavedev/connectors-freshdesk": "workspace:^",
    "@statewavedev/connectors-notion": "workspace:^",
    "@statewavedev/connectors-gmail": "workspace:^",
    "@statewavedev/mcp-server": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^2.1.0",
    "@types/node": "^24.13.1"
  }
}
