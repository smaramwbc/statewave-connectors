{
  "name": "statewave-connectors",
  "private": true,
  "version": "0.0.0",
  "description": "Connector ecosystem for Statewave — feed real-world events into agent memory",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "test": "pnpm -r --filter \"./packages/**\" run test",
    "typecheck": "pnpm -r --filter \"./packages/**\" run typecheck",
    "lint": "pnpm -r --filter \"./packages/**\" run lint",
    "clean": "pnpm -r exec rm -rf dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r --filter \"./packages/**\" run build && changeset publish",
    "pack:all": "pnpm -r --filter \"@statewavedev/*\" exec pnpm pack --pack-destination ../../tarballs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "vitest": "^4.1.10",
      "vite": "^6.4.3",
      "form-data": ">=4.0.6",
      "js-yaml": ">=4.2.0",
      "undici": "^7.28.0",
      "read-yaml-file": "^2.1.0"
    }
  }
}
