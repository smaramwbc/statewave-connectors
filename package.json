{
  "name": "statewave-connectors",
  "private": true,
  "version": "0.0.0",
  "description": "Connector ecosystem for Statewave — feed real-world events into agent memory",
  "license": "Apache-2.0",
  "author": "Statewave <hello@statewave.ai>",
  "homepage": "https://statewave.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaramwbc/statewave-connectors.git"
  },
  "bugs": {
    "url": "https://github.com/smaramwbc/statewave-connectors/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "test": "pnpm -r --filter \"./packages/**\" run test",
    "typecheck": "pnpm -r --filter \"./packages/**\" run typecheck",
    "lint": "pnpm -r --filter \"./packages/**\" run lint",
    "clean": "pnpm -r exec rm -rf dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r --filter \"./packages/**\" run build && changeset publish",
    "pack:all": "pnpm -r --filter \"@statewavedev/*\" --filter \"!@statewavedev/connectors-discord\" --filter \"!@statewavedev/connectors-notion\" --filter \"!@statewavedev/connectors-zendesk\" --filter \"!@statewavedev/connectors-intercom\" --filter \"!@statewavedev/connectors-freshdesk\" --filter \"!@statewavedev/connectors-gmail\" exec pnpm pack --pack-destination ../../tarballs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
